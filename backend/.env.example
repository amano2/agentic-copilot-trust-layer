# Database configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/copilot
# Inside docker-compose, use:
# DATABASE_URL=postgresql://postgres:postgres@postgres_db:5432/copilot

# ChromaDB configuration
CHROMA_HOST=localhost
CHROMA_PORT=8000
# Inside docker-compose, use:
# CHROMA_HOST=chroma_db
# CHROMA_PORT=8000

# OpenRouter API Key for free LLM access
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Backend configuration
PORT=8000
HOST=0.0.0.0
